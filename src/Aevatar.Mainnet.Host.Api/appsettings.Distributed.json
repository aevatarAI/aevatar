{
  "ActorRuntime": {
    "Provider": "Orleans",
    "OrleansStreamBackend": "KafkaStrictProvider",
    "OrleansStreamProviderName": "AevatarOrleansStreamProvider",
    "OrleansActorEventNamespace": "aevatar.actor.events",
    "OrleansPersistenceBackend": "Garnet",
    "OrleansGarnetConnectionString": "localhost:6379",
    "KafkaBootstrapServers": "localhost:9092",
    "KafkaTopicName": "aevatar-mainnet-agent-events",
    "KafkaConsumerGroup": "aevatar-mainnet-host-api"
  },
  "Orleans": {
    "ClusteringMode": "Localhost",
    "ClusterId": "aevatar-mainnet-cluster",
    "ServiceId": "aevatar-mainnet-host-api",
    "SiloHost": "127.0.0.1",
    "PrimarySiloEndpoint": "",
    "SiloPort": 11111,
    "GatewayPort": 30000,
    "QueueCount": 8,
    "QueueCacheSize": 4096
  },
  "Projection": {
    "Document": {
      "Providers": {
        "Elasticsearch": {
          "Enabled": true,
          "Endpoints": [
            "http://localhost:9200"
          ]
        },
        "InMemory": {
          "Enabled": false
        }
      }
    },
    "Graph": {
      "Providers": {
        "Neo4j": {
          "Enabled": true,
          "Uri": "bolt://localhost:7687",
          "Username": "neo4j",
          "Password": "password"
        },
        "InMemory": {
          "Enabled": false
        }
      }
    },
    "Policies": {
      "Environment": "Production",
      "DenyInMemoryDocumentReadStore": true,
      "DenyInMemoryGraphFactStore": true
    }
  }
}
