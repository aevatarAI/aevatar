{
  "name": "aevatar-console-web",
  "version": "6.0.0",
  "private": true,
  "packageManager": "pnpm@10.2.1",
  "description": "Aevatar console shell built on Ant Design Pro",
  "scripts": {
    "analyze": "cross-env ANALYZE=1 max build",
    "build": "max build",
    "build:web": "npm run build",
    "dev": "npm run start:dev",
    "jest": "jest",
    "lint": "npm run biome:lint && npm run tsc",
    "biome:lint": "npx @biomejs/biome lint",
    "preview": "npm run build && max preview --port \"${PORT:-${AEVATAR_CONSOLE_FRONTEND_PORT:-5173}}\"",
    "start": "PORT=\"${PORT:-${AEVATAR_CONSOLE_FRONTEND_PORT:-5173}}\" UMI_ENV=dev max dev",
    "start:dev": "PORT=\"${PORT:-${AEVATAR_CONSOLE_FRONTEND_PORT:-5173}}\" UMI_ENV=dev MOCK=none max dev",
    "test": "jest",
    "test:unit": "jest --selectProjects node",
    "test:ui": "jest --selectProjects jsdom",
    "test:coverage": "npm run jest -- --coverage",
    "tsc": "tsc --noEmit"
  },
  "browserslist": [
    "defaults"
  ],
  "dependencies": {
    "@aevatar-react-sdk/agui": "0.5.0",
    "@aevatar-react-sdk/types": "0.5.0",
    "@ant-design/icons": "^6.1.0",
    "@ant-design/pro-components": "3.1.2-0",
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-query": "^5.90.21",
    "@xyflow/react": "^12.10.1",
    "antd": "^6.2.2",
    "antd-style": "^4.1.0",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.19",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@ant-design/pro-cli": "^3.3.0",
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-modules-commonjs": "^7.28.6",
    "@biomejs/biome": "^2.1.1",
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@types/react-helmet": "^6.1.11",
    "@umijs/lint": "^4.6.13",
    "@umijs/max": "^4.6.25",
    "cross-env": "^10.1.0",
    "express": "^5.2.0",
    "gh-pages": "^6.1.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^16.1.2",
    "mockjs": "^1.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "umi-presets-pro": "^2.0.3",
    "umi-serve": "^1.9.11"
  },
  "engines": {
    "node": ">=18.20.0"
  },
  "create-umi": {
    "ignoreScript": [
      "docker*",
      "functions*",
      "site",
      "generateMock"
    ],
    "ignoreDependencies": [
      "netlify*",
      "serverless"
    ],
    "ignore": [
      ".dockerignore",
      ".git",
      ".github",
      ".gitpod.yml",
      "CODE_OF_CONDUCT.md",
      "Dockerfile",
      "Dockerfile.*",
      "lambda",
      "LICENSE",
      "netlify.toml",
      "README.*.md",
      "azure-pipelines.yml",
      "docker",
      "CNAME",
      "create-umi"
    ]
  }
}
