{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Orleans": "Warning",
      "MassTransit": "Warning"
    }
  },
  "Firebase": {
    "ProjectId": "aevatar-app"
  },
  "App": {
    "Id": "",
    "DisplayName": "Aevatar App",
    "PaywallEnabled": false,
    "TrialAuthEnabled": true,
    "TrialTokenSecret": "dev-secret-32-chars-minimum-here!",
    "Storage": {
      "Region": "",
      "BucketName": "",
      "AccessKeyId": "",
      "SecretAccessKey": "",
      "CdnUrl": ""
    },
    "ImageConcurrency": {
      "MaxTotal": 20,
      "MaxQueueSize": 100,
      "QueueTimeoutMs": 30000
    },
    "Quota": {
      "MaxSavedEntities": 10,
      "MaxEntitiesPerWeek": 3,
      "MaxOperationsPerDay": 3
    },
    "AllowedOrigins": "http://localhost:3000,http://localhost:8081",
    "CompletionPort": {
      "Channel": "aevatar:completion",
      "TimeoutSeconds": 5
    },
    "Projection": {
      "Provider": "Elasticsearch",
      "Elasticsearch": {
        "Endpoints": [ "http://localhost:9200" ],
        "IndexPrefix": "aevatar-app",
        "AutoCreateIndex": true,
        "Username": "",
        "Password": ""
      }
    }
  },
  "Projection": {
    "Document": {
      "Providers": {
        "Elasticsearch": {
          "Enabled": true,
          "Endpoints": [ "http://localhost:9200" ],
          "IndexPrefix": "aevatar-workflow"
        }
      }
    }
  },
  "Tolt": {
    "BaseUrl": "https://api.tolt.com",
    "ApiKey": ""
  },
  "RevenueCat": {
    "WebhookSecret": ""
  },
  "Orleans": {
    "ClusteringMode": "Localhost",
    "ClusterId": "aevatar-app-cluster",
    "ServiceId": "aevatar-app-host-api",
    "SiloPort": 11111,
    "GatewayPort": 30000
  },
  "ActorRuntime": {
    "Provider": "Orleans",
    "OrleansStreamBackend": "MassTransitAdapter",
    "OrleansPersistenceBackend": "Garnet",
    "OrleansGarnetConnectionString": "localhost:6379",
    "MassTransitKafkaBootstrapServers": "localhost:9092",
    "MassTransitKafkaTopicName": "aevatar-app-agent-events",
    "MassTransitKafkaConsumerGroup": "aevatar-app-kafka-streaming"
  }
}
