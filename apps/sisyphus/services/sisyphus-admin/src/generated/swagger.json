	"info": {
		"title": "Sisyphus Admin",
		"version": "1.0.0",
		"description": "Global settings and audit trail service. Manages project-level configuration (graph ID, cron intervals), records audit events from all Sisyphus services, and tracks user login history.",
		"contact": {}
	},
	"paths": {
		"/settings": {
			"get": {
				"operationId": "GetSettings",
				"responses": {
					"200": {
						"description": "Ok",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/SettingsDTO"
								}
							}
						}
					}
				},
				"description": "Get global settings. Returns defaults if never configured.\nOther Sisyphus services call this to retrieve graphId, cron intervals, etc.",
				"summary": "Get settings",
				"tags": [
					"Settings"
				],
				"security": [],
				"parameters": []
			},
