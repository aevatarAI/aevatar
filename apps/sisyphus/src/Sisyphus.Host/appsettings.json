{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Orleans": "Warning",
      "Aevatar": "Warning",
      "System.Net.Http": "Warning"
    }
  },
  "ActorRuntime": {
