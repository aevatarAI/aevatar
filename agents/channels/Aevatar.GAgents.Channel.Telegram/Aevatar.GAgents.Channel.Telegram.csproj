    <AssemblyName>Aevatar.GAgents.Channel.Telegram</AssemblyName>
    <RootNamespace>Aevatar.GAgents.Channel.Telegram</RootNamespace>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
